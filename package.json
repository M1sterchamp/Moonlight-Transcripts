{
  "name": "moonlighthub-transcripts-ui",
  "version": "1.1.0",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node ./node_modules/electron/cli.js .",
    "dist": "node ./node_modules/electron-builder/cli.js"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "build": {
    "appId": "com.moonlighthub.transcripts",
    "productName": "Moonlight Transcripts",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "logo.png",
          "logo.ico"
        ]
      },
      {
        "from": "build/gh-token.txt",
        "to": "gh-token.txt"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "shortcutName": "Moonlight Transcripts",
      "createDesktopShortcut": true,
      "include": "nsis/gh-token.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "M1sterchamp",
        "repo": "Moonlight-Transcripts",
        "private": true
      }
    ]
  }
}